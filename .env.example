# Mobility C2 — environment template (rental / on-prem)
# Copy to .env and edit. Never commit .env with real passwords.

# --- Dashboard HTTP ---
FM_HTTP_PORT=3888
FM_VIDEO_WS_PORT=3889
FM_AUDIO_WS_PORT=3890
HOST=203.0.113.10
FM_GB28181_PUBLIC_HOST=203.0.113.10
FM_GB28181_BIND_HOST=0.0.0.0

# --- BWC SIP: IPv4 only on camera keypad (dynamic SIM — no hostnames) ---
FM_BWC_SIP_IP_ONLY=1

# --- Rental scale (one node per customer today) ---
FM_RENTAL_MODE=1
# FM_RENTAL_PLAN=enterprise   # label only when no license; license type wins when licensed
FM_MAX_BWC_DEVICES=5000
FM_MAX_DASHBOARD_USERS=500
FM_MAX_SUPER_ADMINS=5
FM_MAX_CONCURRENT_LIVE=64

# --- Evidence security (customer pack default) ---
# Operators request AES export; any super admin approves. Set 0 for lab cleartext downloads.
FM_EVIDENCE_SECURE_EXPORT=1

# --- Scale prep Phase A (staging SKU L — opt-in; lab/demo leave off) ---
# FM_USE_CACHE_DEBOUNCE=1
# FM_GPS_CACHE_DEBOUNCE_MS=2000
# FM_CONTACT_CACHE_DEBOUNCE_MS=2000
# FM_GPS_EMIT_BATCH_MS=300
# FM_FLEET_ROSTER_THROTTLE_MS=5000
# FM_FTP_USED_FILES_MAX=50000
# FM_FTP_USED_FILES_TTL_MS=86400000

# --- Site node (5K + 5K topology — one node per install) ---
FM_SITE_NODE_ID=site-a
# FM_SITE_PEER_URL=http://192.168.1.9:3888

# --- Archive tier: local | nas | cloud (customer choice) ---
FM_ARCHIVE_PRIMARY=local
# FM_ARCHIVE_NAS_PATH=\\nas01\evidence\site-a
FM_CATALOG_MODE=postgres_required
FM_CATALOG_DB_URL=postgresql://mobility:change_me@127.0.0.1:5432/mobility
# FM_ARCHIVE_CLOUD_ENDPOINT=https://s3.example.com
# FM_ARCHIVE_CLOUD_BUCKET=mobility-evidence-site-a

# --- Platform license (vendor-signed storage/platform-license.json) ---
# Required when FM_RENTAL_MODE=1. Issued from MobilityC2-VENDOR-IMPORTANT/LicenseIssuer (NOT this server).
# FM_LICENSE_REQUIRED=0   # internal dev only — skip license check

# --- ffmpeg: bundled only (npm install → ffmpeg-static) ---
FM_REQUIRE_BUNDLED_FFMPEG=1
# FM_FFMPEG_ALLOW_SYSTEM=1
# FFMPEG_BIN=

# --- SIP ---
FM_GB28181_SIP_PORT=5060
FM_GB28181_PLATFORM_ID=34020000002000000001
FM_GB28181_REALM=3402000000
FM_GB28181_PASSWORD=change-me
FM_GB28181_PASSWORD_ALT=change-me
FM_MEDIA_TRANSPORT=udp
FM_MSG_WS_PORT=6000
FM_MEDIA_AUDIO=1
# Live listen buffer before PCM (ms). Default 500; 100 = faster start.
# FM_AUDIO_PRIME_MS=100

# --- PTT (optional) ---
FM_PTT_ENABLED=1
FM_PTT_PORT=29201
FM_PTT_GTID=49
FM_PTT_GROUP_STATUS=1
# PTT HQ→BWC downlink dwCMD: auto | 130 | legacy (4)
# auto = per-BWC column in Server → BWC list, then learned uplink, env legacy list, UB-prefix → cmd 4
FM_PTT_DOWNLINK_CMD=auto
# Optional camId overrides (same as BWC column "Legacy") — prefer BWC admin column for new devices
# FM_PTT_DOWNLINK_LEGACY_CAMIDS=34020000001329000009
# UB-class model prefix → cmd 4 in auto mode (default UB). Override: FM_PTT_AUDIO_CMD_MODEL_PREFIXES=UB
# Hold fleet 🎙 uses SIP voice call instead of PTT TCP downlink (camId override only)
# FM_PTT_VOICE_FALLBACK_CAMIDS=34020000001329000009
# Model prefix → voice on HQ hold PTT (default UB-X). UB-class uses PTT.
FM_PTT_VOICE_MODEL_PREFIXES=UB

# --- Fleet ☎ voice path (all BWCs — no per-nickname tuning) ---
# Outbound Talk (platform SIP INVITE) vs SIP Broadcast MESSAGE is chosen automatically:
#   1) FM_VOICE_BROADCAST_CAMIDS forces broadcast for listed camIds
#   2) FM_VOICE_OUTBOUND_INTERCOM_CAMIDS forces outbound Talk for listed camIds
#   3) Else if PTT login user or bwc-devices userName starts with a prefix in
#      FM_VOICE_OUTBOUND_MODEL_PREFIXES → outbound Talk for every matching device
#   4) Else → broadcast
# Production: set prefixes for your fleet (e.g. UB). Use camId lists only for
# odd firmware that does not report a model string on PTT login.
# FM_VOICE_OUTBOUND_MODEL_PREFIXES=UB
# FM_VOICE_OUTBOUND_INTERCOM_CAMIDS=
# FM_VOICE_BROADCAST_CAMIDS=
# SDK §8 intercom matrix (Fleet ☎ outbound INVITE — bench / engineer only):
#   Set in .env on the lab bench only — not in Settings UI. Default: talk-duplex (no line needed).
#   talk-duplex      Talk + y/f + sendrecv (default)
#   talk-minimal     Talk subject, no y/f
#   talk-recvonly    Talk + y/f, SDP recvonly
#   phone-channel0   Phone session, subject :0 (+ StopRecord on connect)
# FM_VOICE_INTERCOM_PROFILE=talk-duplex
# Fleet ☎ SIP mic TX gain 0–1 (same for all BWCs). Default 0.7.
# FM_VOICE_CALL_TX_GAIN=0.7

# --- FTP / docking station (optional) ---
FM_FTP_ENABLED=1
FM_FTP_PORT=21
FM_FTP_USER=
FM_FTP_PASS=
FM_FTP_PASV_MIN=20000
FM_FTP_PASV_MAX=20100
# Optional override (absolute or relative to app). Otherwise set in Server config → Docking.
# FM_FTP_ROOT=storage/ftp-uploads

# --- HTTPS evidence upload (hybrid deployments) ---
# Replaces FTP for internet-facing deployments. Set a strong random token (min 32 chars).
# Cameras or relay agents POST to /api/evidence/upload with Authorization: Bearer <token>
# Leave blank to disable (FTP-only mode). For LAN-only deployments FTP is sufficient.
# FM_HTTPS_UPLOAD_TOKEN=

# --- SOS ledger PIN (optional) ---
# FM_SOS_LEDGER_PIN=
# Days of SOS history shown in fleet sidebar list (default 3; dashboard uses 30 in UI)
# FM_SOS_LEDGER_DAYS=7

# --- Vendor / field-engineer diagnostics (NOT dashboard password) ---
# Unlocks Server config → Diagnostics tab + /api/tech/* health, trace, runbooks.
# Issue PIN from your office only; never give to customer operators. Min 12 characters.
# FM_TECH_ENGINEER_PIN=
# FM_TRACE=1

# --- Centre Summary built-in AI (ships in vendor/llm/ — customers do not download) ---
# Vendor once: powershell -File scripts\download-centre-llm.ps1  then ship vendor\llm\ with installer
# FM_LLM_AUTO_DOWNLOAD=0
# FM_LLM_MODEL_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf
# FM_LLM_WARMUP=1

# --- Advanced feature licenses (controlled by vendor — do not expose to customers) ---
# Set to 1 to enable for this deployment. Leave blank / 0 to disable.
# These flags are server-side only — the browser receives only a boolean result, never the key values.
# FM_LICENSE_FR=0           # Facial Recognition (Analytics hub — Facenet/SFace; never VGG-Face)
# FM_LICENSE_ANPR=0         # Automatic Number Plate Recognition (Tesseract.js, Apache-2.0)
# FM_LICENSE_REDACTION=0    # Video Redaction tool in Evidence vault

# --- Face recognition service (demo PC or server) ---
# Enterprise (UbitronC2 service): FM_FR_SIDECAR_AUTO=1 — C2 starts face matching in background (no START-FR.bat).
# Lab / debug only: double-click START-FR.bat if AUTO=0.
# License for Analytics FR: FM_LICENSE_FR=1
# FM_FR_SIDECAR_URL=http://127.0.0.1:8765
# FM_FR_SIDECAR_AUTO=1      # 0 = manual START-FR.bat only
# FM_FR_ENGINE=onnx         # ship/code default (mob-fr-engine-cutover) → fr-sidecar-fast :8766
# FM_FR_ENGINE=deepface     # backup / rollback → fr-sidecar :8765
# FM_FR_ENGINE=seeta        # reserved
# FM_FR_SIDECAR_FAST_PORT=8766
# FM_FR_FAST_PY=            # optional explicit path to fr-sidecar-fast\.venv\Scripts\python.exe
# FM_FR_FALLBACK_DEEPFACE=0
# FM_FR_ONNX_PACK=buffalo_sc  # mob-fr-onnx-pack-off — small lab pack; Seeta is next (not DeepFace)
# LEGAL: buffalo_* pretrained = non-commercial research unless InsightFace commercial license
#        docs/MOB-DISC-FR-ONNX-PACK-COMMERCIAL-LICENSE.md — do not ship without license or Seeta/cleared engine
# FM_FR_MODEL=Facenet       # Facenet | Facenet512 | SFace only (DeepFace path)
# FM_FR_DETECTOR=opencv
# --- Video conference MCU (LiveKit — open source Apache-2.0) ---
# Prefer: scripts/START-LIVEKIT.ps1 (builds docker/livekit.runtime.yaml from template + keys)
# LAB-DEFAULT-CREDS-AND-IMAGE-PIN-V1 — lab fallbacks OK on bench; set strong keys before customer expose
# FM_LIVEKIT_URL=http://127.0.0.1:7880
# FM_LIVEKIT_API_KEY=devkey
# FM_LIVEKIT_API_SECRET=secret
# Client WebSocket (phones/browsers). If unset, derived from dashboard Host when URL above is localhost.
# FM_LIVEKIT_PUBLIC_WS=ws://192.168.1.38:7880
# FM_LIVEKIT_PUBLIC_WS=wss://dispatch.customer.com:7880
# FM_LIVEKIT_TURN_URL=turn:your-host:3478
# FM_LIVEKIT_EDGE_URL=http://192.168.1.8:7880
# --- WVP lab stack (docker/wvp) — LAB ONLY defaults; change before customer expose ---
# WVP_PWD=admin123
# WVP_DB_USER=root
# WVP_DB_PASSWORD=root123
# WVP_REDIS_PASSWORD=root
# FM_CONFERENCE_RTP_BASE=40200
