# ME8 commercial bench / ship template — copy to .env and edit.
# Never commit .env with real passwords. No lab camId lists in this profile.
#
# ENV RULES (ship):
# - Ubitron builder / NEW-ME8-INSTALL.ps1 writes this file once (ports, HOST, bootstrap).
# - Operators configure FTP, SIP, users in Settings — never edit .env.
# - Bench-only tuning (engineer / lab): FM_VOICE_INTERCOM_PROFILE, FM_TRACE, FM_SOS_COLD_PULL_MS, etc.

PORT=3988
HOST=YOUR_LAN_IP
FM_HTTP_PORT=3988
FM_MAX_CONCURRENT_LIVE=8
FM_VIDEO_WS_PORT=3989
FM_AUDIO_PRIME_MS=500
FM_MEDIA_TRANSPORT=udp

# Fresh install: empty seed — add BWCs in super-admin only
FM_SEED_BWC_ID=
FM_SEED_BWC_NICKNAME=

# Dual-protocol lab: Fleet SIP/YDT = 5062; WVP GB video = host 5060 (proxy).
FM_GB28181_ENABLED=1
FM_GB28181_SIP_PORT=5062
FM_GB28181_PLATFORM_ID=34020000002000000001
FM_GB28181_REALM=3402000000
FM_GB28181_PASSWORD=change-me
FM_GB28181_PASSWORD_ALT=change-me
FM_GB28181_PUBLIC_HOST=YOUR_LAN_IP
FM_GB28181_BIND_HOST=0.0.0.0
FM_GB28181_RTP_PORT=50050
FM_GB28181_REQUIRE_AUTH=0
# 6000 = standard BWC message WS. Use 6100 only if trial ship runs side-by-side on same host.
FM_MSG_WS_PORT=6000

FM_PTT_ENABLED=1
FM_PTT_PORT=29201
FM_PTT_GTID=49
FM_PTT_GROUP_STATUS=1
FM_PTT_DOWNLINK_CMD=auto
FM_PTT_VOICE_MODEL_PREFIXES=UB
FM_VOICE_OUTBOUND_MODEL_PREFIXES=UB

# SDK §8 intercom matrix (Fleet ☎ — bench / engineer only, not Settings UI):
#   Default talk-duplex. Uncomment one profile for lab SIP matrix trials.
# FM_VOICE_INTERCOM_PROFILE=talk-duplex
# FM_VOICE_INTERCOM_PROFILE=talk-minimal
# FM_VOICE_INTERCOM_PROFILE=talk-recvonly
# FM_VOICE_INTERCOM_PROFILE=phone-channel0

# FTP — BWC dock upload. Match port + password on each device.
# Cyber / pen-test: WAN port 21 fails most scans — prefer 2121 on LAN; block 21 on firewall (mob-ftp-bind-lan PARKED).
FM_FTP_ENABLED=1
FM_FTP_PORT=2121
FM_FTP_USER=
FM_FTP_PASS=
FM_FTP_PASV_MIN=20000
FM_FTP_PASV_MAX=20100

# Optional: 32-byte master key (base64 or 64-char hex) for secrets vault encryption.
# If unset, Windows DPAPI wraps a per-machine key under storage/secrets/vault-key.dpapi.
# FM_SECRETS_MASTER_KEY=
# FM_SECRETS_DPAPI_SCOPE=LocalMachine

# ME8 ship default: debounce GPS + SIP contact disk writes (reduces I/O under fleet load).
# Set FM_USE_CACHE_DEBOUNCE=0 to restore legacy synchronous writes (lab debug only).
FM_USE_CACHE_DEBOUNCE=1
FM_GPS_CACHE_DEBOUNCE_MS=2000
FM_CONTACT_CACHE_DEBOUNCE_MS=2000

# mob-me8-ops-runtime — SOS incident path (override in .env if needed)
FM_SOS_COLD_PULL_MS=850
FM_LOGIN_REPLAY_SOS_PAUSE_MS=60000

FM_MAP_OFFLINE_ONLY=0

# Bench only — suspend super-admin TOTP (password login only). REMOVE before ship.
# FM_TOTP_SUSPENDED=1

# --- FR Analytics lab UI (ME8 dev only — hide preview toolbar on customer ship) ---
# FM_FR_LAB_UI=1   # shows Analytics "Preview alert/toast (lab)" buttons; unset = hidden
# FM_FR_ALERT_TIER=1   # poi/monitoring → rail+ledger only; suspect+blacklist interrupt (set 0 = legacy all interrupt)
# FM_FR_MAP_AUTO_SCORE_MIN=75   # Blacklist auto Ops+map+pin at/above this % (default 75 = match floor)
# FM_FR_AUTO_GO_OPS=1
# FM_FR_AUTO_MAP=1
# FM_FR_AUTO_GO_OPS_SUSPECT=0   # unused for auto (suspect never auto-dispatch after colour MOB)

# --- FR engine (mob-fr-engine-cutover: code default = onnx) ---
# FM_FR_ENGINE=onnx              # ship/code default → fr-sidecar-fast :8766
# FM_FR_ENGINE=deepface          # backup / rollback → fr-sidecar :8765
# FM_FR_ENGINE=seeta             # reserved — not wired yet
# FM_FR_SIDECAR_FAST_PORT=8766
# FM_FR_FAST_PY=                 # optional fr-sidecar-fast\.venv\Scripts\python.exe
# FM_FR_FALLBACK_DEEPFACE=0
# FM_FR_ONNX_PACK=buffalo_sc  # mob-fr-onnx-pack-off — small lab pack; next quality = Seeta (not DeepFace)
# LEGAL: InsightFace pretrained packs = non-commercial research unless commercially licensed.
#         See docs/MOB-DISC-FR-ONNX-PACK-COMMERCIAL-LICENSE.md — lab proof ≠ customer ship.
# FM_FR_BATCH_PROBE=1            # mob-fr-poller-batch-grab — N grabs → one batch HTTP (0 = legacy serial)
# FM_FR_GRAB_MS=900              # mob-fr-snap-grab-faster — still wait after first bytes (was 1800)
# FM_FR_GRAB_EOF_MS=200          # flush wait after ending grab pipe
# FM_FR_GRAB_NO_DATA_MS=800      # fail-fast if live pool sends no bytes
# FM_FR_BEST_FRAME_GRABS=2       # stills per poll window (was 3)
# FM_FR_BEST_FRAME_GAP_MS=200    # gap between stills (was 350)
# Watchlist must be ONNX-embedded (Re-embed gallery) before trusting matches.

# --- Control room Monitor 3 profile (map = default; analytics = FR watch pop-out) ---
# FM_DISPLAY_MONITOR3=map
# FM_DISPLAY_MONITOR3=analytics

# --- Gate B ZLM lab bench (builder only — not operator Docker) ---
# --- ZLM (Gate B lab Docker OR mvp-zlm-in-pack child process) ---
# Lab Docker (builder only — never tell customer to install Docker):
# FM_LAB_ZLM=1
# FM_ZLM_ENABLED=1
# FM_ZLM_HTTP=http://127.0.0.1:8080
# FM_ZLM_SECRET=<match docker/zlm-config/config.ini or vendor/zlmediakit/config.ini>
# FM_ZLM_APP=live
# FM_ZLM_RTMP=rtmp://127.0.0.1:19350
# Pack (one install — no Docker): place MediaServer.exe via scripts/INSTALL-ZLM-PACK.ps1 then:
# FM_ZLM_ENABLED=1
# FM_ZLM_SPAWN=1
# FM_ZLM_PACK=1
# FM_ZLM_HTTP=http://127.0.0.1:8080
# FM_ZLM_RTMP=rtmp://127.0.0.1:19350
# FM_ZLM_SECRET=<same as vendor/zlmediakit/config.ini [api] secret>
# Start ZLM (builder lab): docker compose -p me8-zlm -f docker/zlm.compose.yml up -d
# Test page: http://<HOST>:3988/test-zlm.html?camId=<BWC_ID>
# FLV plays via dashboard proxy /api/lab/zlm/flv/… (not WAN :8080)

# --- Enterprise (Phase B Wave 0 — env only; Fleet wiring in later MOBs) ---
# Full reference: docs/ME8-ENV-ENTERPRISE.md
# docker compose -f docker/docker-compose.enterprise.yml up -d
#
# FM_REDIS_URL=redis://127.0.0.1:6379
# FM_CATALOG_DB_URL=postgresql://mobility:mobility_dev_change_me@127.0.0.1:5432/mobility
# FM_CATALOG_MODE=postgres_required
# FM_CATALOG_ALLOW_SQLITE_QUEUE=0
# Or merge: copy from .env.enterprise.example

# --- Video conference (LiveKit) — optional; see docs/ME8-COMPOSE-LAYOUT.md ---
# .\scripts\START-LIVEKIT.ps1
# FM_LIVEKIT_URL=http://127.0.0.1:7880
# FM_LIVEKIT_PUBLIC_WS=ws://YOUR_LAN_IP:7880
# FM_LIVEKIT_API_KEY=devkey
# FM_LIVEKIT_API_SECRET=secret
