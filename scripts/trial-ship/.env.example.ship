# Mobility Axiom — environment template (on-prem / trial)
# Copy to .env and edit. Never commit .env with real passwords.

# --- Dashboard HTTP ---
FM_HTTP_PORT=3888
FM_VIDEO_WS_PORT=3889
FM_AUDIO_WS_PORT=3890
HOST=203.0.113.10
FM_GB28181_PUBLIC_HOST=203.0.113.10
FM_GB28181_BIND_HOST=0.0.0.0

# --- BWC SIP: IPv4 only on camera keypad (dynamic SIM — no hostnames) ---
FM_BWC_SIP_IP_ONLY=1

# --- Rental scale (one node per customer) ---
FM_RENTAL_MODE=1
FM_MAX_BWC_DEVICES=5000
FM_MAX_DASHBOARD_USERS=500
FM_MAX_SUPER_ADMINS=5
FM_MAX_CONCURRENT_LIVE=64

# --- Evidence security ---
FM_EVIDENCE_SECURE_EXPORT=1

# --- Site node ---
FM_SITE_NODE_ID=site-a

# --- Archive tier: local | nas | cloud ---
FM_ARCHIVE_PRIMARY=local

# --- Platform license (vendor-signed storage/platform-license.json) ---
# Required when FM_RENTAL_MODE=1. Issued by your Mobility Axiom vendor.
# FM_LICENSE_REQUIRED=1

# --- Media tools (bundled with installer — do not remove) ---
FM_REQUIRE_BUNDLED_FFMPEG=1

# --- SIP listener (body-worn camera register) ---
FM_GB28181_SIP_PORT=5060
FM_GB28181_PLATFORM_ID=34020000002000000001
FM_GB28181_REALM=3402000000
FM_GB28181_PASSWORD=change-me
FM_GB28181_PASSWORD_ALT=change-me
FM_MEDIA_TRANSPORT=udp
FM_MSG_WS_PORT=6000
FM_MEDIA_AUDIO=1

# --- PTT (optional) ---
FM_PTT_ENABLED=1
FM_PTT_PORT=29201
FM_PTT_GTID=49
FM_PTT_GROUP_STATUS=1
FM_PTT_DOWNLINK_CMD=auto
FM_PTT_VOICE_MODEL_PREFIXES=UB

# --- FTP / docking station (optional) ---
FM_FTP_ENABLED=1
FM_FTP_PORT=21
FM_FTP_USER=
FM_FTP_PASS=
FM_FTP_PASV_MIN=20000
FM_FTP_PASV_MAX=20100

# --- Trial: do not auto-seed demo BWC on first run ---
FM_SEED_BWC_ID=

# --- Centre Summary assistant (bundled in installer — no internet download at site) ---
FM_LLM_AUTO_DOWNLOAD=0
FM_LLM_WARMUP=1

# --- Video conference (on-server media service) ---
FM_LIVEKIT_URL=http://127.0.0.1:7880
FM_LIVEKIT_API_KEY=devkey
FM_LIVEKIT_API_SECRET=secret
FM_LIVEKIT_PUBLIC_WS=ws://127.0.0.1:7880
