# ME8 enterprise overlay — Valkey + Postgres (Phase B Wave 0).
# Copy lines into .env after: docker compose -f docker/docker-compose.enterprise.yml up -d
# Fleet does NOT read these until mob-redis-client / mob-pg-adapter MOBs ship.
# See docs/ME8-ENV-ENTERPRISE.md

# --- Valkey (Redis protocol) — GPS / online / SIP contact cache ---
# Leave unset on lab bench without Docker enterprise stack.
FM_REDIS_URL=redis://127.0.0.1:6379
# FM_REDIS_CONNECT_TIMEOUT_MS=5000
# FM_REDIS_KEY_PREFIX=me8:

# --- PostgreSQL catalog — evidence metadata, BWC registry, audit ---
FM_CATALOG_DB_URL=postgresql://mobility:mobility_dev_change_me@127.0.0.1:5432/mobility

# postgres_required = refuse catalog writes when PG down (enterprise default)
# sqlite_shadow   = dev only — JSON/SQLite primary until PG MOBs wired
# off             = ignore PG URL (same as unset today)
FM_CATALOG_MODE=postgres_required

# When PG is down: 0 = HTTP 503 on catalog writes (ship default)
#                   1 = queue to WAL + SQLite pending (lab / single-VM — see doc 07)
FM_CATALOG_ALLOW_SQLITE_QUEUE=0

# Optional WAL path (relative to app root). Default: storage/catalog-sync-wal.jsonl
# FM_CATALOG_WAL_PATH=storage/catalog-sync-wal.jsonl

# --- Stability (Wave 1 — ME8 ship default) ---
FM_USE_CACHE_DEBOUNCE=1
FM_GPS_CACHE_DEBOUNCE_MS=2000
FM_CONTACT_CACHE_DEBOUNCE_MS=2000
