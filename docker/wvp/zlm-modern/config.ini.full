[cluster]
# Φ«╛τ╜«µ║Éτ½Öµïëµ╡üurlµ¿íµ¥┐, µá╝σ╝ÅΦ╖ƒprintfτ▒╗Σ╝╝∩╝îτ¼¼Σ╕ÇΣ╕¬%sµîçσ«Üapp,τ¼¼Σ║îΣ╕¬%sµîçσ«Üstream_id,
# σ╝ÇσÉ»Θ¢åτ╛ñµ¿íσ╝ÅσÉÄ∩╝îon_stream_not_foundσÆîon_stream_none_reader hookσ░åµùáµòê.
# µ║»µ║Éµ¿íσ╝Åµö»µîüΣ╗ÑΣ╕ïτ▒╗σ₧ï:
# rtmpµû╣σ╝Å: rtmp://127.0.0.1:1935/%s/%s
# rtspµû╣σ╝Å: rtsp://127.0.0.1:554/%s/%s
# hlsµû╣σ╝Å: http://127.0.0.1:80/%s/%s/hls.m3u8
# http-tsµû╣σ╝Å: http://127.0.0.1:80/%s/%s.live.ts
# µö»µîüσñÜΣ╕¬µ║Éτ½Ö∩╝îΣ╕ìσÉîµ║Éτ½ÖΘÇÜΦ┐çσêåσÅ╖(;)σêåΘÜö
# Origin pull URL template (printf style: first `%s` is app, second `%s` is stream_id).
# When cluster mode is enabled, `on_stream_not_found` and `on_stream_none_reader` webhooks are disabled.
# Supported origin pull protocols:
# RTMP mode: rtmp://127.0.0.1:1935/%s/%s
# RTSP mode: rtsp://127.0.0.1:554/%s/%s
# HLS mode: http://127.0.0.1:80/%s/%s/hls.m3u8
# HTTP-TS mode: http://127.0.0.1:80/%s/%s.live.ts
# Separate multiple origin servers with semicolons (;).
origin_url=
# µ║»µ║ÉµÇ╗Φ╢àµù╢µù╢Θò┐∩╝îσìòΣ╜ìτºÆ∩╝îfloatσ₧ï∩╝¢σüçσªéµ║Éτ½Öµ£ë3Σ╕¬∩╝îΘéúΣ╣êσìòµ¼íµ║»µ║ÉΦ╢àµù╢µù╢Θù┤Σ╕║timeout_secΘÖñΣ╗Ñ3
# σìòµ¼íµ║»µ║ÉΦ╢àµù╢µù╢Θù┤Σ╕ìΦªüΦ╢àΦ┐çgeneral.maxStreamWaitMSΘàìτ╜«
# Total origin pull timeout in seconds (float).
# The single origin attempt timeout (total timeout divided by the number of origins) should not exceed `general.maxStreamWaitMS`.
timeout_sec=15
# µ║»µ║Éσñ▒Φ┤Ñσ░¥Φ»òµ¼íµò░∩╝î-1µù╢µ░╕Σ╣àσ░¥Φ»ò
# Failure retry attempts for origin pulling (-1 for infinite retries).
retry_count=3

[http]
# httpµ£ìσèíσÖ¿σ¡ùτ¼ªτ╝ûτáüΘ¢å
# HTTP server character encoding.
charSet=utf-8
# httpΘô╛µÄÑΦ╢àµù╢µù╢Θù┤
# HTTP connection timeout in seconds.
keepAliveSecond=30
# httpΦ»╖µ▒éΣ╜ôµ£Çσñºσ¡ùΦèéµò░∩╝îσªéµ₧£postτÜäbodyσñ¬σñº∩╝îσêÖΣ╕ìΘÇéσÉêτ╝ôσ¡ÿbodyσ£¿σåàσ¡ÿ
# Maximum number of bytes for the HTTP request body. If the POST body is too large, it is not suitable to cache the body in memory.
maxReqSize=40960
# 404τ╜æΘí╡σåàσ«╣∩╝îτö¿µê╖σÅ»Σ╗ÑΦç¬σ«ÜΣ╣ë404τ╜æΘí╡
# Custom 404 page content. Users can customize the 404 response page here.
#notFound=<html><head><title>404 Not Found</title></head><body bgcolor="white"><center><h1>µé¿Φ«┐Θù«τÜäΦ╡äµ║ÉΣ╕ìσ¡ÿσ£¿∩╝ü</h1></center><hr><center>ZLMediaKit-4.0</center></body></html>
# httpµ£ìσèíσÖ¿τ¢æσÉ¼τ½»σÅú
# HTTP server listening port.
port=80
# httpµûçΣ╗╢µ£ìσèíσÖ¿µá╣τ¢«σ╜ò
# σÅ»Σ╗ÑΣ╕║τ¢╕σ»╣(τ¢╕σ»╣Σ║Äµ£¼σÅ»µëºΦíîτ¿ïσ║Åτ¢«σ╜ò)µêûτ╗¥σ»╣Φ╖»σ╛ä
# HTTP file server root directory (relative or absolute path).
rootPath=./www
# httpµûçΣ╗╢µ£ìσèíσÖ¿Φ»╗µûçΣ╗╢τ╝ôσ¡ÿσñºσ░Å∩╝îσìòΣ╜ìBYTE∩╝îΦ░âµò┤Φ»ÑσÅéµò░σÅ»Σ╗ÑΣ╝ÿσîûµûçΣ╗╢ioµÇºΦâ╜
# HTTP file server read cache size in bytes. Tweak to optimize file I/O performance.
sendBufSize=65536
# httpsµ£ìσèíσÖ¿τ¢æσÉ¼τ½»σÅú
# HTTPS server listening port.
sslport=443
# µÿ»σÉªµÿ╛τñ║µûçΣ╗╢σñ╣ΦÅ£σìò∩╝îσ╝ÇσÉ»σÉÄσÅ»Σ╗Ñµ╡ÅΦºêµûçΣ╗╢σñ╣
# Whether to enable directory browsing menus.
dirMenu=1
# ΦÖÜµïƒτ¢«σ╜ò, ΦÖÜµïƒτ¢«σ╜òσÉìσÆîµûçΣ╗╢Φ╖»σ╛äΣ╜┐τö¿","ΘÜöσ╝Ç∩╝îσñÜΣ╕¬Θàìτ╜«Φ╖»σ╛äΘù┤τö¿";"ΘÜöσ╝Ç
# Σ╛ïσªéΦ╡ïσÇ╝Σ╕║ app_a,/path/to/a;app_b,/path/to/b ΘéúΣ╣ê
# Φ«┐Θù« http://127.0.0.1/app_a/file_a σ»╣σ║öτÜäµûçΣ╗╢Φ╖»σ╛äΣ╕║ /path/to/a/file_a
# Φ«┐Θù« http://127.0.0.1/app_b/file_b σ»╣σ║öτÜäµûçΣ╗╢Φ╖»σ╛äΣ╕║ /path/to/b/file_b
# Φ«┐Θù«σà╢Σ╗ûhttpΦ╖»σ╛ä,σ»╣σ║öτÜäµûçΣ╗╢Φ╖»σ╛äΦ┐ÿµÿ»σ£¿rootPathσåà
# Virtual directory mappings. Format: virtual_name,path;virtual_name,path (name and file path separated by ",", multiple mappings separated by ";").
# For example, set `app_a,/path/to/a;app_b,/path/to/b` then:
# Accessing `http://127.0.0.1/app_a/file_a` maps to `/path/to/a/file_a`.
# Accessing `http://127.0.0.1/app_b/file_b` maps to `/path/to/b/file_b`, while other HTTP paths still map to files under `rootPath`.
virtualPath=
# τªüµ¡óσÉÄτ╝ÇτÜäµûçΣ╗╢Σ╜┐τö¿mmapτ╝ôσ¡ÿ∩╝îΣ╜┐τö¿ΓÇ£,ΓÇ¥ΘÜöσ╝Ç
# Σ╛ïσªéΦ╡ïσÇ╝Σ╕║ .mp4,.flv
# ΘéúΣ╣êΦ«┐Θù«σÉÄτ╝ÇΣ╕║.mp4Σ╕Ä.flv τÜäµûçΣ╗╢Σ╕ìτ╝ôσ¡ÿ
# Disables `mmap` caching for specific file extensions. Use `,` to separate multiple extensions.
# Example: `.mp4,.flv` means files with these extensions bypass the `mmap` cache.
forbidCacheSuffix=
# σÅ»Σ╗ÑµèèhttpΣ╗úτÉåσëìτ£ƒσ«₧σ«óµê╖τ½»ipµö╛σ£¿httpσñ┤Σ╕¡∩╝Ühttps://github.com/ZLMediaKit/ZLMediaKit/issues/1388
# σêçσï┐µÜ┤Θ£▓µ¡ñkey∩╝îσÉªσêÖσÅ»Φâ╜σ»╝Φç┤Σ╝¬ΘÇáσ«óµê╖τ½»ip
# Header name to trust for extracting the real client IP from an HTTP proxy request header. See: https://github.com/ZLMediaKit/ZLMediaKit/issues/1388
# Do not expose this key, as it may lead to forged client IPs.
forwarded_ip_header=
# Θ╗ÿΦ«ñσàüΦ«╕µëÇµ£ëΦ╖¿σƒƒΦ»╖µ▒é
# Whether to allow all cross-origin requests by default (sets generic CORS headers).
allow_cross_domains=1
# σàüΦ«╕Φ«┐Θù«http apiσÆîhttpµûçΣ╗╢τ┤óσ╝òτÜäipσ£░σ¥ÇΦîâσ¢┤τÖ╜σÉìσìò∩╝îτ╜«τ⌐║µâàσå╡Σ╕ïΣ╕ìσüÜΘÖÉσê╢
# IP whitelist ranges allowed to access the HTTP API and file indexes. Leave empty to allow any IP without restrictions.
allow_ip_range=::1,127.0.0.1,172.16.0.0-172.31.255.255,192.168.0.0-192.168.255.255,10.0.0.0-10.255.255.255

[multicast]
# rtpτ╗äµÆ¡µê¬µ¡óτ╗äµÆ¡ipσ£░σ¥Ç
# Maximum IP address for the multicast pool.
addrMax=239.255.255.255
# rtpτ╗äµÆ¡Φ╡╖σºïτ╗äµÆ¡ipσ£░σ¥Ç
# Minimum IP address for the multicast pool.
addrMin=239.0.0.0
# τ╗äµÆ¡udp ttl
# TTL (Time to Live) for multicast UDP packets.
udpTTL=64

[record]
# mp4σ╜òσê╢µêûmp4τé╣µÆ¡τÜäσ║öτö¿σÉì∩╝îΘÇÜΦ┐çΘÖÉσê╢σ║öτö¿σÉì∩╝îσÅ»Σ╗ÑΘÿ▓µ¡óΘÜÅµäÅτé╣µÆ¡
# τé╣µÆ¡τÜäµûçΣ╗╢σ┐àΘí╗µö╛τ╜«σ£¿µ¡ñµûçΣ╗╢σñ╣Σ╕ï
# Application name for MP4 recording/VOD. Restricting this prevents unauthorized VOD access.
# VOD files must be placed within this specific folder.
appName=record
# mp4σ╜òσê╢σåÖµûçΣ╗╢τ╝ôσ¡ÿ∩╝îσìòΣ╜ìBYTE,Φ░âµò┤σÅéµò░σÅ»Σ╗ÑµÅÉΘ½ÿµûçΣ╗╢ioµÇºΦâ╜
# MP4 recording write cache size in bytes. Tweak to optimize file I/O performance.
fileBufSize=65536
# mp4τé╣µÆ¡µ»Åµ¼íµ╡üσîûµò░µì«ΘçÅ∩╝îσìòΣ╜ìµ»½τºÆ∩╝î
# σçÅσ░æΦ»ÑσÇ╝σÅ»Σ╗ÑΦ«⌐τé╣µÆ¡µò░µì«σÅæΘÇüΘçÅµ¢┤σ╣│µ╗æ∩╝îσó₧σñºΦ»ÑσÇ╝σêÖµ¢┤Φèéτ£ücpuΦ╡äµ║É
# Duration (in ms) of MP4 data streamed per VOD transmission block.
# Decreasing this value smooths transmission; increasing it saves CPU resources.
sampleMS=500
# mp4σ╜òσê╢σ«îµêÉσÉÄµÿ»σÉªΦ┐¢ΦíîΣ║îµ¼íσà│Θö«σ╕ºτ┤óσ╝òσåÖσàÑσñ┤Θâ¿
# Whether to write a secondary keyframe index into the MP4 header after recording completes (fast start).
fastStart=0
# MP4τé╣µÆ¡(rtsp/rtmp/http-flv/ws-flv)µÿ»σÉªσ╛¬τÄ»µÆ¡µö╛µûçΣ╗╢
# Controls whether MP4 VOD playback (rtsp/rtmp/http-flv/ws-flv) loops the file when it reaches the end.
fileRepeat=0
# MP4σ╜òσê╢σåÖµûçΣ╗╢µá╝σ╝Åµÿ»σÉªΘççτö¿fmp4∩╝îσÉ»τö¿τÜäΦ»¥∩╝îµû¡τö╡µ£¬σ«îµêÉσ╜òσê╢τÜäµûçΣ╗╢Σ╣ƒΦâ╜µ¡úσ╕╕µëôσ╝Ç
# Whether to use the fmp4 format for MP4 recording. Enables normal playback of interrupted recordings (e.g., due to power loss).
enableFmp4=0

[rtmp]
# rtmpσ┐àΘí╗σ£¿µ¡ñµù╢Θù┤σåàσ«îµêÉµÅíµëï∩╝îσÉªσêÖµ£ìσèíσÖ¿Σ╝Üµû¡σ╝ÇΘô╛µÄÑ∩╝îσìòΣ╜ìτºÆ
# RTMP handshake timeout in seconds. The server drops the connection if not completed.
handshakeSecond=15
# rtmpΦ╢àµù╢µù╢Θù┤∩╝îσªéµ₧£Φ»Ñµù╢Θù┤σåàµ£¬µö╢σê░σ«óµê╖τ½»τÜäµò░µì«∩╝î
# µêûΦÇàtcpσÅæΘÇüτ╝ôσ¡ÿΦ╢àΦ┐çΦ┐ÖΣ╕¬µù╢Θù┤∩╝îσêÖΣ╝Üµû¡σ╝ÇΦ┐₧µÄÑ∩╝îσìòΣ╜ìτºÆ
# RTMP keep-alive timeout in seconds. Connections drop if no data from the client is received,
# or if the TCP send buffer stall exceeds this duration.
keepAliveSecond=15
# rtmpµ£ìσèíσÖ¿τ¢æσÉ¼τ½»σÅú
# RTMP server listening port.
port=1935
# rtmpsµ£ìσèíσÖ¿τ¢æσÉ¼σ£░σ¥Ç
# RTMPS server listening port.
sslport=0
# rtmpµÿ»σÉªτ¢┤µÄÑΣ╗úτÉåµ¿íσ╝Å
# Whether to enable direct proxy mode for RTMP.
directProxy=1
# h265/opus/vp8/vp9/av1 rtmpµëôσîàΘççτö¿σó₧σ╝║σ₧ïrtmpµáçσçåΦ┐ÿµÿ»σ¢╜σåàµïôσ▒òµáçσçå
# Whether RTMP packaging for H265/Opus/VP8/VP9/AV1 uses the Enhanced RTMP standard (1) or the domestic extended standard (0).
enhanced=1

[rtp]
# Θƒ│Θóæmtuσñºσ░Å∩╝îΦ»ÑσÅéµò░ΘÖÉσê╢rtpµ£Çσñºσ¡ùΦèéµò░∩╝îµÄ¿ΦìÉΣ╕ìΦªüΦ╢àΦ┐ç1400
# σèáσñºΦ»ÑσÇ╝Σ╝ÜµÿÄµÿ╛σó₧σèáτ¢┤µÆ¡σ╗╢µù╢
# Audio MTU size (restricts max RTP payload in bytes). We recommend keeping this <= 1400.
# Increasing this value significantly increases live streaming latency.
audioMtuSize=600
# ΦºåΘóæmtuσñºσ░Å∩╝îΦ»ÑσÅéµò░ΘÖÉσê╢rtpµ£Çσñºσ¡ùΦèéµò░∩╝îµÄ¿ΦìÉΣ╕ìΦªüΦ╢àΦ┐ç1400
# Video MTU size (restricts max RTP payload in bytes). We recommend keeping this <= 1400.
videoMtuSize=1400
# rtpσîàµ£ÇσñºΘò┐σ║ªΘÖÉσê╢∩╝îσìòΣ╜ìKB,Σ╕╗Φªüτö¿Σ║ÄΦ»åσê½TCPΣ╕èΣ╕ïµûçτá┤σ¥Åµù╢∩╝îΦÄ╖σÅûσê░ΘöÖΦ»»τÜärtp
# Max RTP packet length in KB. Mainly used to identify receiving wrong RTP packets when TCP stream contexts are corrupted.
rtpMaxSize=10
# rtp µëôσîàµù╢∩╝îΣ╜Äσ╗╢Φ┐ƒσ╝Çσà│∩╝îΘ╗ÿΦ«ñσà│Θù¡∩╝êΣ╕║0∩╝ë∩╝îh264σ¡ÿσ£¿Σ╕Çσ╕ºσñÜΣ╕¬slice∩╝êNAL∩╝ëτÜäµâàσå╡∩╝îσ£¿Φ┐Öτºìµâàσå╡Σ╕ï∩╝îσªéµ₧£σ╝ÇσÉ»σÅ»Φâ╜Σ╝Üσ»╝Φç┤τö╗Θ¥óΦè▒σ▒Å
# Low-latency mode for RTP packaging (disabled by default). Enabling this for H.264 video with multiple slices per frame may cause visual artifacts (glitches).
lowLatency=0
# H264 rtpµëôσîàµ¿íσ╝Åµÿ»σÉªΘççτö¿stap-aµ¿íσ╝Å(Σ╕║Σ║åσ£¿ΦÇüτëêµ£¼µ╡ÅΦºêσÖ¿Σ╕èσà╝σ«╣webrtc)Φ┐ÿµÿ»Θççτö¿Single NAL unit packet per H.264 µ¿íσ╝Å
# µ£ëΣ║¢ΦÇüτÜärtspΦ«╛σñçΣ╕ìµö»µîüstap-a rtp∩╝îΦ«╛τ╜«µ¡ñΘàìτ╜«Σ╕║0σÅ»µÅÉΘ½ÿσà╝σ«╣µÇº
# Whether H.264 RTP packaging uses the `stap-a` mode (for older WebRTC browser compatibility) or the `Single NAL unit packet per H.264` mode.
# Set this to 0 to improve compatibility with legacy RTSP devices that do not support `stap-a`.
h264_stap_a=1

[rtp_proxy]
# σ»╝σç║Φ░âΦ»òµò░µì«(σîàµï¼rtp/ps/h264)Φç│Φ»Ñτ¢«σ╜ò,τ╜«τ⌐║σêÖσà│Θù¡µò░µì«σ»╝σç║
# Directory for exporting debugging data (rtp/ps/h264). Leave empty to disable.
dumpDir=
# udpσÆîtcpΣ╗úτÉåµ£ìσèíσÖ¿∩╝îµö»µîürtp(σ┐àΘí╗µÿ»tsµêûpsτ▒╗σ₧ï)Σ╗úτÉå
# UDP/TCP proxy server listening port. Supports RTP proxying (must be TS or PS).
port=10000
# rtpΦ╢àµù╢µù╢Θù┤∩╝îσìòΣ╜ìτºÆ
# RTP timeout in seconds.
timeoutSec=15
# ΘÜÅµ£║τ½»σÅúΦîâσ¢┤∩╝îµ£Çσ░æτí«Σ┐¥36Σ╕¬τ½»σÅú
# Φ»ÑΦîâσ¢┤σÉîµù╢ΘÖÉσê╢rtspµ£ìσèíσÖ¿udpτ½»σÅúΦîâσ¢┤
# Random port range (ensure at least 36 ports).
# This also restricts the UDP port range for the RTSP server.
port_range=30000-35000
# rtp h264 Φ┤ƒΦ╜╜τÜäpt
# RTP payload type (PT) for H.264.
h264_pt=98
# rtp h265 Φ┤ƒΦ╜╜τÜäpt
# RTP payload type (PT) for H.265.
h265_pt=99
# rtp ps Φ┤ƒΦ╜╜τÜäpt
# RTP payload type (PT) for PS.
ps_pt=96
# rtp opus Φ┤ƒΦ╜╜τÜäpt
# RTP payload type (PT) for Opus.
opus_pt=100
# startSendRtpπÇüstartRecordτ¢╕σà│σèƒΦâ╜µÿ»σÉªµÅÉσëìσ╝ÇσÉ»gopτ╝ôσ¡ÿΣ╝ÿσîûτ║ºΦüöτºÆσ╝ÇΣ╜ôΘ¬î∩╝îΘ╗ÿΦ«ñσ╝ÇσÉ», σ╣╢τ╝ôσ¡ÿ1Σ╕¬GOP
# σªéµ₧£Σ╕ìΦ░âτö¿startSendRtpπÇüstartRecordσÉÄτ¢╕σà│µÄÑσÅú∩╝îσÅ»Σ╗Ñτ╜«0Φèéτ£üσåàσ¡ÿ∩╝¢σªéµ₧£τ╝ôσ¡ÿσñÜΣ╕¬gop∩╝îσÅ»Σ╗ÑσèáσñºΦ»ÑσÅéµò░
# Whether to pre-enable GOP caching for `startSendRtp` and `startRecord` to optimize instant playback for cascaded streams. Enabled by default, caching 1 GOP.
# If these functions are unused, set to 0 to save memory; to cache multiple GOPs, increase this value.
