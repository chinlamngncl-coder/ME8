# ps/tsΦºúµ₧ÉσÉÄµÿ»σÉªτ¡ëσ╛àΣ╕ïΣ╕Çσ╕ºΣ╗Ñσêñµû¡µ£¼σ╕ºµÿ»σÉªσ«îµò┤∩╝îσ╝ÇσÉ»σÉÄµÅÉΘ½ÿσà╝σ«╣µÇº∩╝îΣ╜åµÿ»σÅ»Φâ╜σó₧σèáσ╗╢µù╢
# Whether to wait for the next frame after parsing PS/TS to verify frame completeness. Improves compatibility but may increase latency.
merge_frame=1

[rtc]
# webrtc Σ┐íΣ╗ñµ£ìσèíσÖ¿τ½»σÅú
# WebRTC signaling server port.
signalingPort=3000
