# Mobility Axiom PostgreSQL primary catalog.
# Copy lines into .env after: docker compose -f docker/docker-compose.enterprise.yml up -d
# See docs/ME8-ENV-ENTERPRISE.md

# --- PostgreSQL catalog — evidence metadata, BWC registry, audit ---
FM_CATALOG_DB_URL=postgresql://mobility:mobility_dev_change_me@127.0.0.1:5432/mobility

# Required: startup fails before listeners if PostgreSQL is unavailable.
FM_CATALOG_MODE=postgres_required
FM_CATALOG_CONNECT_TIMEOUT_MS=5000
FM_CATALOG_QUERY_TIMEOUT_MS=15000
FM_CATALOG_POOL_MAX=10
