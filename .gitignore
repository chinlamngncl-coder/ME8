# ---- Secrets & credentials (NEVER commit) ----
.env
.env.*
!.env.example
!.env.me8.example
!.env.enterprise.example
!scripts/trial-ship/.env.example.ship
keys/
storage/

# ---- Dependencies ----
node_modules/
vendor/node-win-x64-cache/
# Centre Summary weights — download locally; bundled in customer pack only
vendor/llm/*.gguf
vendor/llm/*.part

# Media engine (LGPL) binary — download via scripts/download-ffmpeg-lgpl.ps1; bundled in customer pack only
vendor/ffmpeg-lgpl/*.exe
vendor/ffmpeg-lgpl/*.dll

# ---- Android build output ----
mobile-android/**/build/
mobile-android/**/.gradle/
mobile-android/**/.cxx/

# ---- Large local backups / snapshots (scripts + manifests tracked) ----
baseline/**
!baseline/**/
!baseline/**/CREATE-ME8-V1.ps1
!baseline/**/RESTORE-ME8-V1.ps1
!baseline/**/VERIFY-ME8-V1.ps1
!baseline/**/CREATE-ME8-FIRMWARE-GOLD.ps1
!baseline/**/RESTORE-ME8-FIRMWARE-GOLD.ps1
!baseline/**/VERIFY-ME8-FIRMWARE-GOLD.ps1
!baseline/**/MANIFEST.json
!baseline/**/HASHES.json

# ---- Runtime / build output ----
evidence/
dist/

# ---- Logs & generated temp ----
*.log
logs/
scripts/_keys-output.txt
scripts/_gen-keys-once.js

# ZLM lab runtime config (secret generated on first container start)
docker/zlm-config/config.ini

# ---- OS / editor cruft ----
Thumbs.db
.DS_Store
!.cursor/rules/
!.cursor/rules/*.mdc
